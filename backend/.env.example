# ---- Server ----
PORT=4000
ALLOWED_ORIGIN=https://your-portfolio-domain.com

# ---- Contact form (Gmail example — use an App Password, not your real password) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password
CONTACT_TO=tahleel.shaikh@example.com

# ---- GitHub (for live PR + contribution stats) ----
# Create a fine-grained Personal Access Token with read-only access to
# public repos (no special scopes needed for public data via GraphQL).
# Never expose this token in frontend code — it stays server-side only.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
